# Unreal Engine Remote Control API (Edit > Plugins > Remote Control API)
UE_HOST=127.0.0.1
UE_HTTP_PORT=30010
UE_WS_PORT=30020
UE_REQUEST_TIMEOUT_MS=5000

# Optional: path to your .uproject (for future headless/build tools)
# UE_PROJECT_PATH=/path/to/MyGame/MyGame.uproject

# Set to true to run without a live editor (stub responses for development)
UE_MOCK_MODE=false
