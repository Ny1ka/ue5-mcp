{
  "mcpServers": {
    "ue5-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/absolute/path/to/ue5-mcp",
        "ue5-mcp"
      ],
      "env": {
        "UE_HOST": "127.0.0.1",
        "UE_HTTP_PORT": "30010",
        "UE_MOCK_MODE": "false"
      }
    }
  }
}
